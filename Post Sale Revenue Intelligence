    if(persist) localStorage.setItem('xgs_view',v);
    history.replaceState(null,'','#'+v);
  }

  navLinks.forEach(a=>a.addEventListener('click',e=>{e.preventDefault(); setView(a.dataset.view);}));
  document.querySelectorAll('[data-view-jump]').forEach(b=>b.addEventListener('click',()=>setView(b.dataset.viewJump)));

  const hashView = (location.hash||'').replace('#','');
  setView(hashView || localStorage.getItem('xgs_view') || 'overview', false);

  // Theme
  const themeToggle = document.getElementById('themeToggle');
  const initialDark = localStorage.getItem('xgs_theme')==='dark';
  if(initialDark) document.body.classList.add('dark');
