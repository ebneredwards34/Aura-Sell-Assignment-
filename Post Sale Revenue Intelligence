    themeToggle.textContent = isDark ? 'Light mode' : 'Dark mode';
    themeToggle.setAttribute('aria-pressed', String(isDark));
  });

  // Print brief
  document.getElementById('printBrief').addEventListener('click',()=>window.print());

  // Architecture expand/collapse
  const layerEls = [...document.querySelectorAll('details.layer')];
  document.getElementById('expandLayers').addEventListener('click',()=>layerEls.forEach(d=>d.open=true));
  document.getElementById('collapseLayers').addEventListener('click',()=>layerEls.forEach(d=>d.open=false));

  // Play drawer
  const drawer = document.getElementById('playDrawer');
  const drawerBody = document.getElementById('drawerBody');
  document.getElementById('closeDrawer').addEventListener('click',()=>drawer.classList.remove('open'));
