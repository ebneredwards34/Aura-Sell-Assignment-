    li.textContent = `${runningAccount} — ${runningPlay} moved to In Progress via Play Runner.`;
    activity.prepend(li);
    toast(`Play launched: ${runningPlay}`);
  });
  document.getElementById('wizardClose').addEventListener('click',()=>wizard.classList.remove('open'));

  // Sprint launch
  document.querySelectorAll('.launch-sprint').forEach(btn=>btn.addEventListener('click',()=>{
    const col = document.querySelector('.column[data-col="Planned"]');
    const task = document.createElement('div');
    task.className='task'; task.textContent = `${btn.dataset.sprint}: newly launched`; col.appendChild(task);
    toast(`Sprint launched: ${btn.dataset.sprint}`);
  }));

  // Analytics tabs
  document.querySelectorAll('.tab').forEach(btn=>btn.addEventListener('click',()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.tab-panel').forEach(p=>p.hidden=true);
    document.getElementById('tab-'+btn.dataset.tab).hidden=false;
  }));

  // Copy buttons
  document.querySelectorAll('[data-copy]').forEach(btn=>btn.addEventListener('click', async()=>{
    const id = btn.dataset.copy; const text = document.getElementById(id)?.innerText || '';
    try { await navigator.clipboard.writeText(text); toast('Copied to clipboard'); } catch { toast('Clipboard unavailable'); }
  }));

  // Export config
  document.getElementById('exportConfig').addEventListener('click',()=>{
    const config = {
      signal_freshness_decay_days: Number(document.getElementById('cfgDecay').value),
      confidence_threshold: Number(document.getElementById('cfgConfidence').value),
      play_eligibility_rule: document.getElementById('cfgEligibility').value,
      package_default: document.getElementById('cfgPackage').value,
      generated_at: new Date().toISOString()
    };
    const blob = new Blob([JSON.stringify(config,null,2)], {type:'application/json'});
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download='secureai-growth-os-config.json';
    document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(a.href);
    toast('Configuration exported');
  });

  // Global search filter
  globalSearch.addEventListener('input',()=>{
    const q = globalSearch.value.trim().toLowerCase();
    document.querySelectorAll('.searchable').forEach(v=>{
      const txt = v.innerText.toLowerCase();
      v.dataset.matches = !q || txt.includes(q) ? '1':'0';
    });

    const active = document.querySelector('.view.active');
    if(active && active.id==='view-overview'){
      const rows = [...document.querySelectorAll('#queueTable tbody tr')];
      let shown = 0;
      rows.forEach(r=>{ const keep = !q || r.innerText.toLowerCase().includes(q); r.hidden=!keep; if(keep) shown++; });
      document.getElementById('queueEmpty').hidden = shown!==0;
    }

    // if current view doesn't match, still keep visible but show empty helper
    const existing = active.querySelector('.empty.dynamic-empty');
    if(existing) existing.remove();
    if(q && active.dataset.matches==='0'){
      const e = document.createElement('div'); e.className='empty dynamic-empty'; e.textContent='No results in this view for current filter.';
      active.prepend(e);
    }
  });
})();
</script>
</body>
</html>
