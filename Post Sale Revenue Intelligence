<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Xerox SecureAI Growth OS — Post-Sale Revenue System (IT • AI • Security)</title>
  <style>
    :root {
      --bg: #f3f6fb;
      --surface: #ffffff;
      --surface-2: #f8fbff;
      --text: #152130;
      --muted: #5b6b7d;
      --border: #d4deeb;
      --primary: #0b57d0;
      --primary-soft: #eaf1ff;
      --accent: #0f766e;
      --warn: #b45309;
      --danger: #b42318;
      --shadow: 0 1px 2px rgba(16,24,40,.08), 0 12px 28px rgba(16,24,40,.06);
      --radius: 12px;
      --focus: #ffbf47;
    }
    body.dark {
      --bg: #0d1624;
      --surface: #121d2c;
      --surface-2: #182437;
      --text: #e8eef8;
      --muted: #9fb0c6;
      --border: #2b3a53;
      --primary: #7cb2ff;
      --primary-soft: #1d2f48;
      --accent: #5fd6be;
      --warn: #f2b25f;
      --danger: #ff8d8d;
      --shadow: 0 1px 2px rgba(0,0,0,.4), 0 16px 30px rgba(0,0,0,.28);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: "Segoe UI", Roboto, Arial, sans-serif;
      line-height: 1.45;
    }
    a { color: var(--primary); text-decoration: none; }
    a:hover { text-decoration: underline; }
    :focus-visible {
      outline: 3px solid var(--focus);
      outline-offset: 2px;
      border-radius: 6px;
    }

    .app {
      min-height: 100vh;
      display: grid;
      grid-template-rows: 64px 1fr;
    }

    header.appbar {
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      display: grid;
      grid-template-columns: auto auto 1fr auto auto;
      gap: .8rem;
      align-items: center;
      padding: .6rem 1rem;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .brand { font-weight: 700; white-space: nowrap; }
    .pill {
      border: 1px solid var(--border);
      background: var(--surface-2);
      border-radius: 999px;
      padding: .2rem .6rem;
      font-size: .78rem;
      color: var(--muted);
      white-space: nowrap;
    }

    .search {
      width: 100%;
      max-width: 560px;
      justify-self: center;
      position: relative;
    }
    .search input {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: .55rem .7rem;
      font-size: .95rem;
      color: var(--text);
      background: var(--surface);
    }

    button, select, textarea, input {
      font: inherit;
      color: inherit;
    }

    .btn {
      border: 1px solid var(--border);
      background: var(--surface);
      padding: .5rem .75rem;
      border-radius: 10px;
      cursor: pointer;
    }
    .btn:hover { background: var(--surface-2); }
    .btn.primary {
      background: var(--primary);
      border-color: var(--primary);
      color: #fff;
    }
    .btn.primary:hover { filter: brightness(1.05); }

    .workspace {
      display: grid;
      grid-template-columns: 250px 1fr;
      min-height: calc(100vh - 64px);
    }

    nav.sidenav {
      border-right: 1px solid var(--border);
      background: var(--surface);
      padding: .85rem;
      position: sticky;
      top: 64px;
      align-self: start;
      max-height: calc(100vh - 64px);
      overflow: auto;
    }

    .nav-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: .4rem;
    }
    .nav-link {
      display: block;
      border: 1px solid transparent;
      border-radius: 10px;
      padding: .55rem .7rem;
      color: var(--text);
    }
    .nav-link:hover { background: var(--surface-2); text-decoration: none; }
    .nav-link.active {
      border-color: #b8cef6;
      background: var(--primary-soft);
      color: var(--primary);
      font-weight: 600;
    }

    .content {
      padding: 1rem;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .breadcrumbs {
      margin: 0 0 .8rem;
      color: var(--muted);
      font-size: .9rem;
    }

    .view { display: none; }
    .view.active { display: block; }

    .grid { display: grid; gap: .9rem; }
    .grid.kpis { grid-template-columns: repeat(4,minmax(0,1fr)); }
    .grid.two { grid-template-columns: repeat(2,minmax(0,1fr)); }
    .grid.three { grid-template-columns: repeat(3,minmax(0,1fr)); }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: .9rem;
    }
    .card h2,.card h3 { margin: 0 0 .45rem; }
    .muted { color: var(--muted); }

    .kpi .value { font-size: 1.35rem; font-weight: 700; }
    .kpi .delta { color: var(--accent); font-size: .86rem; }

    table {
      width: 100%; border-collapse: collapse; font-size: .9rem;
    }
    th, td {
      text-align: left; border-bottom: 1px solid var(--border); padding: .5rem .3rem;
      vertical-align: top;
    }
    th { color: var(--muted); font-weight: 600; }

    .status {
      font-size: .78rem; padding: .12rem .45rem; border-radius: 999px;
      border: 1px solid var(--border); display: inline-block;
    }
    .s-new { background: #eef4ff; color: #1f4ea5; }
    .s-progress { background: #ecfdf3; color: #0f5132; }
    .s-blocked { background: #fff4e5; color: #8b5e00; }
    .s-won { background: #ebfff7; color: #116149; }

    .activity { list-style: none; margin: 0; padding: 0; display: grid; gap: .5rem; }
    .activity li { border-left: 3px solid var(--primary); padding-left: .6rem; }

    .cta {
      display: flex; align-items: center; justify-content: space-between; gap: .7rem;
      background: linear-gradient(180deg,var(--primary-soft),transparent);
    }

    details.layer {
      border: 1px solid var(--border); border-radius: 10px; padding: .55rem .75rem; margin-bottom: .55rem; background: var(--surface);
    }
    details.layer summary { cursor: pointer; font-weight: 600; }

    .pipeline { display: flex; flex-wrap: wrap; gap: .4rem; align-items: center; }
    .pipeline span { background: var(--surface-2); border: 1px solid var(--border); padding: .3rem .55rem; border-radius: 999px; }

    .play-lane h3 { margin-bottom: .6rem; }
    .play-card { border: 1px solid var(--border); border-radius: 10px; padding: .65rem; background: var(--surface-2); }
    .chips { display: flex; flex-wrap: wrap; gap: .35rem; }
    .chip { border: 1px solid var(--border); border-radius: 999px; padding: .1rem .45rem; font-size: .78rem; }

    .drawer {
      position: fixed; top: 64px; right: -430px; width: min(420px,95vw); height: calc(100vh - 64px);
      background: var(--surface); border-left: 1px solid var(--border); box-shadow: var(--shadow);
      padding: 1rem; overflow: auto; transition: right .2s ease; z-index: 20;
    }
    .drawer.open { right: 0; }

    .gauge { margin-bottom: .5rem; }
    .bar {
      height: 10px; width: 100%; border-radius: 999px; background: var(--surface-2); border: 1px solid var(--border); overflow: hidden;
    }
    .bar > i { display: block; height: 100%; background: linear-gradient(90deg,var(--primary),var(--accent)); }

    .reco { border: 1px solid var(--border); border-radius: 10px; padding: .65rem; margin-bottom: .55rem; background: var(--surface-2); }

    .wizard { position: fixed; inset: 0; background: rgba(0,0,0,.45); display: none; z-index: 40; }
    .wizard.open { display: grid; place-items: center; }
    .wizard-panel {
      width: min(860px,96vw); max-height: 92vh; overflow: auto;
      background: var(--surface); border: 1px solid var(--border); border-radius: 14px; box-shadow: var(--shadow); padding: 1rem;
    }
    .steps { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: .8rem; }

    .kanban { display: grid; grid-template-columns: repeat(5,minmax(0,1fr)); gap: .6rem; }
    .column { border: 1px solid var(--border); border-radius: 10px; background: var(--surface-2); padding: .5rem; min-height: 130px; }
    .task { border: 1px solid var(--border); border-radius: 8px; background: var(--surface); padding: .4rem; margin-bottom: .4rem; font-size: .85rem; }

    .tabs { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: .8rem; }
    .tab.active { border-color: #b8cef6; background: var(--primary-soft); color: var(--primary); }

    svg.chart { width: 100%; height: 200px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface-2); }

    .matrix td,.matrix th { text-align: center; }

    .toast-wrap { position: fixed; right: 1rem; bottom: 1rem; z-index: 60; display: grid; gap: .5rem; }
    .toast { background: var(--surface); border: 1px solid var(--border); box-shadow: var(--shadow); border-left: 4px solid var(--accent); padding: .55rem .7rem; border-radius: 8px; min-width: 220px; }

    .tooltip { position: relative; cursor: help; border-bottom: 1px dashed var(--muted); }
    .tooltip:hover::after, .tooltip:focus-visible::after {
      content: attr(data-tip); position: absolute; left: 0; top: 110%; z-index: 30;
      background: var(--text); color: var(--surface); padding: .35rem .45rem; border-radius: 6px; width: 220px; font-size: .78rem;
    }

    .empty { border: 1px dashed var(--border); border-radius: 8px; padding: .7rem; color: var(--muted); text-align: center; }

    .brief { display: none; }

    @media (max-width: 1100px) {
      .grid.kpis { grid-template-columns: repeat(2,minmax(0,1fr)); }
      .grid.two,.grid.three { grid-template-columns: 1fr; }
      .kanban { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 860px) {
      .workspace { grid-template-columns: 1fr; }
      nav.sidenav { position: static; top: auto; max-height: none; }
      header.appbar { grid-template-columns: 1fr 1fr; grid-auto-rows: auto; }
      .search { grid-column: 1 / -1; max-width: none; }
      .kanban { grid-template-columns: 1fr; }
    }

    @media print {
      header.appbar, nav.sidenav, .workspace > .content > :not(.brief), .toast-wrap, .drawer, .wizard { display: none !important; }
      .brief { display: block !important; }
      body { background: #fff; color: #000; }
      .brief .card { box-shadow: none; border-color: #c8c8c8; break-inside: avoid; }
      details.layer { padding-bottom: .6rem; }
      details.layer:not([open]) > *:not(summary) { display: block; }
    }
  </style>
</head>
